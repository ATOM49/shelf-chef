# Authentication (Google OAuth)
# Google callback URL for local development:
# http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Authentication (GitHub OAuth)
# Optional. The provider is currently disabled in src/auth.ts.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auth.js secret (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Dev-only email/password login (e.g. for Playwright), bypasses OAuth.
# Never enabled in production, even if set — see src/auth.ts.
ENABLE_DEV_LOGIN=
DEV_LOGIN_PASSWORD=

# PostgreSQL database connection string
# Use the direct postgres:// connection string for Prisma ORM.
# For Prisma Postgres, use the direct connection string instead of prisma:// or prisma+postgres://.
# Use sslmode=verify-full (or omit sslmode) to avoid pg SSL deprecation warnings.
# Example: postgres://user:password@host:5432/database?sslmode=verify-full
DATABASE_URL=

# LLM planner defaults
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_ENABLE_GOOGLE_SEARCH=true

# AI provider credentials
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Recipe image generation
# Vercel Blob provides BLOB_READ_WRITE_TOKEN when the private Blob store is connected.
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
BLOB_READ_WRITE_TOKEN=

# Optional shared API key override
LLM_API_KEY=

# Tavily API key for recipe search
TAVILY_API_KEY=

# Optional MCP playground OAuth providers
MCP_NOTION_MCP_CLIENT_ID=
MCP_NOTION_MCP_CLIENT_SECRET=
MCP_GITHUB_MCP_CLIENT_ID=
MCP_GITHUB_MCP_CLIENT_SECRET=
