{
  "name": "stockpot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.19.0 <21",
    "npm": ">=10 <11"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=20.19.0 <21",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=10 <11",
      "onFail": "error"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "test:e2e": "playwright test",
    "generate:preset-seeds": "NEXT_PUBLIC_APP_URL=http://localhost:3000 npx tsx scripts/generate-preset-seeds.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@langchain/anthropic": "^1.1.0",
    "@langchain/google": "^0.1.10",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/openai": "^1.1.0",
    "@lottiefiles/dotlottie-react": "^0.19.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "emoji-picker-react": "^4.18.0",
    "langchain": "^1.3.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.20.0",
    "posthog-node": "^5.40.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "^7.8.0",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
